rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // -------------------------------------------------------------------------
    // Global Safety Net & Helpers
    // -------------------------------------------------------------------------
    match /{document=**} {
      allow read, write: if false;
    }

    function isSignedIn() {
      return request.auth != null;
    }

    function isEmailVerified() {
      return isSignedIn() && request.auth.token.email_verified == true;
    }

    function isAdmin() {
      return isSignedIn() && 
        (request.auth.token.email == 'speed.thunder.postman@gmail.com' ||
         (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
          get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'ADMIN'));
    }

    match /test/connection {
      allow read: if true;
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    // -------------------------------------------------------------------------
    // Users Collection
    // -------------------------------------------------------------------------
    function isValidUser(data) {
      return data.keys().hasAll(['displayName', 'email', 'role', 'createdAt']) &&
             data.displayName is string && data.displayName.size() <= 100 &&
             data.email is string && data.email.size() <= 100 &&
             data.role in ['USER', 'ADMIN'] &&
             data.createdAt is timestamp;
    }

    match /users/{userId} {
      allow get: if isSignedIn() && (request.auth.uid == userId || isAdmin());
      allow list: if isAdmin();
      allow create: if isSignedIn() && request.auth.uid == userId && 
                      isValidUser(incoming()) && 
                      incoming().role == 'USER' && 
                      (incoming().createdAt == request.time || !('createdAt' in incoming()));
      allow update: if isSignedIn() && (request.auth.uid == userId || isAdmin()) &&
                      isValidUser(incoming()) &&
                      (isAdmin() || (incoming().role == existing().role));
    }

    // -------------------------------------------------------------------------
    // Products Collection
    // -------------------------------------------------------------------------
    function isValidProduct(data) {
      return data.keys().hasAll(['name', 'category']) &&
             data.name is string && data.name.size() <= 100 &&
             data.category is string && data.category.size() <= 100;
    }

    match /products/{productId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // -------------------------------------------------------------------------
    // Categories Collection
    // -------------------------------------------------------------------------
    match /categories/{categoryId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // -------------------------------------------------------------------------
    // Orders Collection
    // -------------------------------------------------------------------------
    function isValidOrder(data) {
      return data.keys().hasAll(['items', 'totalAmount', 'status', 'createdAt', 'userId', 'customerName', 'orderNumber']) &&
             data.items is list && data.items.size() > 0 &&
             data.totalAmount is number && data.totalAmount >= 0 &&
             data.status in ['PENDING', 'PREPARING', 'READY', 'COMPLETED', 'CANCELLED'] &&
             data.userId is string &&
             data.customerName is string &&
             data.orderNumber is number;
    }

    match /orders/{orderId} {
      allow list: if isAdmin() || (isSignedIn() && resource.data.userId == request.auth.uid);
      allow get: if isAdmin() || (isSignedIn() && resource.data.userId == request.auth.uid);
      allow create: if isSignedIn() && 
                      isValidOrder(incoming()) && 
                      incoming().status == 'PENDING' &&
                      incoming().userId == request.auth.uid;
      allow update: if isAdmin() && 
                      isValidOrder(incoming()) &&
                      incoming().userId == existing().userId;
    }
  }
}
